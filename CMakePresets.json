{
  "version": 3,
  "configurePresets": [
    {
      "name": "windows-msvc-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "cl.exe",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "🔍 Debug (MSVC/Ninja)",
      "inherits": "windows-msvc-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "⚡ Release (MSVC/Ninja)",
      "inherits": "windows-msvc-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "InterviewAssistant-Debug",
      "displayName": "📦 InterviewAssistant - Debug",
      "configurePreset": "debug",
      "targets": ["InterviewAssistant"]
    },
    {
      "name": "InterviewAssistant-Release",
      "displayName": "📦 InterviewAssistant - Release",
      "configurePreset": "release",
      "targets": ["InterviewAssistant"]
    },
    {
      "name": "Sandbox-Debug",
      "displayName": "🔧 Sandbox - Debug",
      "configurePreset": "debug",
      "targets": ["Sandbox"]
    }
  ]
}